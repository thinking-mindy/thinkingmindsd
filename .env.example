# ─── Required for production web / server deployments ─────────────────────────

# Strong random string (32+ chars). Signs licence anchor files on disk.
# Generate: openssl rand -hex 32
LICENSE_ANCHOR_SECRET=

# Encrypts all local JSON database files at rest (AES-256-GCM).
# Generate: openssl rand -hex 32
LOCAL_DB_ENCRYPTION_KEY=

# Public URL of your deployment (used for PayNow callbacks and links)
NEXT_PUBLIC_APP_URL=https://your-domain.example

# ─── Authentication (cloud mode with Clerk) ───────────────────────────────────

# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# CLERK_WEBHOOK_SECRET=

# ─── Optional: remote MongoDB (cloud sync / licence refresh) ────────────────

# MONGODB_URI=
# MONGODB_URI_REMOTE=

# ─── Optional: PayNow payments ────────────────────────────────────────────────

# PAYNOW_INTEGRATION_ID=
# PAYNOW_INTEGRATION_KEY=
# PAYNOW_MERCHANT_EMAIL=
# PAYNOW_RETURN_URL=
# PAYNOW_RESULT_URL=

# ─── Optional: licence renewal link override ────────────────────────────────

# NEXT_PUBLIC_LICENSE_RENEWAL_URL=/renew-licence
# NEXT_PUBLIC_LICENSE_RENEWAL_EXTERNAL_URL=https://www.thinkingminds.co.zw/renew-licence
# NEXT_PUBLIC_LICENSE_RENEWAL_API_BASE=https://www.thinkingminds.co.zw

# POST endpoint — body: { "companyId", "orgId", "companyName"? } → { "licenseExpiresAt", ... }
# LICENSE_SYNC_URL=https://www.thinkingminds.co.zw/renew-licence

# ─── Desktop / Tauri offline builds (set before npm run tauri:prepare) ───────

# Desktop builds use stable Thinking Minds defaults when unset (no per-machine setup):
# LICENSE_ANCHOR_SECRET=thinkingminds-minds-license-anchor-v1
# LOCAL_DB_ENCRYPTION_KEY=thinkingminds-minds-local-db-v1
# NEXT_PUBLIC_OFFLINE_LOGIN_SECRET=thinkingminds-minds-offline-login-v1
# NEXT_PUBLIC_OFFLINE_SECRETS_SALT=
# NEXT_PUBLIC_TAURI=1
# NEXT_PUBLIC_APP_URL=http://127.0.0.1:43123
