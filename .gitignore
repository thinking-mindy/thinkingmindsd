# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist/

# tauri artifacts
/src-tauri/target
/src-tauri/gen
/src-tauri/resources/*.zip
.desktop-build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local
.env

# runtime data — never commit org DB, licence anchors, or login secrets
/db/*
!/db/README.md
/secrets/*
!/secrets/README.md
!/secrets/license-anchor.json.example
/SERCRETS/

# vercel
.vercel

# typescript
*.tsbuildinfo
# next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/
