{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thinking Minds ERP",
  "version": "5.0.0",
  "identifier": "co.thinkingmindserp.erp",
  "build": {
    "beforeBuildCommand": "npm run tauri:prepare",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Thinking Minds ERP",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": {
      "resources/README.md": "README.md"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
